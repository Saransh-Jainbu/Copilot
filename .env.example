# DevOps Copilot - Environment Variables
# Copy this to .env and fill in your values

# HuggingFace API Token (required for LLM inference)
HUGGINGFACE_API_TOKEN=hf_your_token_here

# GitHub Token (optional, for higher API rate limits when scraping logs)
GITHUB_TOKEN=ghp_your_token_here

# MLflow
MLFLOW_TRACKING_URI=mlruns

# App Config
APP_ENV=development
LOG_LEVEL=INFO

# Latency tuning
HF_MAX_TOKENS=320
HF_TIMEOUT_SECONDS=18
HF_MAX_RETRIES=1
HF_RESPONSE_CACHE_SIZE=64
AGENT_MAX_CONTEXT_RESULTS=3
AGENT_MAX_CONTEXT_CHARS=2000
AGENT_MAX_ERROR_SECTION_CHARS=2000
AGENT_MAX_DIAGNOSIS_TOKENS=320
AGENT_MAX_CRITIQUE_TOKENS=96
PRELOAD_RAG_ON_STARTUP=false
PRELOAD_EMBEDDINGS_ON_STARTUP=false
