# DevOps Copilot - Environment Variables
# Copy this to .env and fill in your values

# HuggingFace API Token (required for LLM inference)
HUGGINGFACE_API_TOKEN=hf_your_token_here

# LLM Model IDs (Hugging Face Inference Providers chat completions endpoint)
# Format: provider/model:strategy (strategy can be :fastest, :cheapest, :preferred, or omitted)
# Examples: openai/gpt-oss-120b:fastest, deepseek-ai/DeepSeek-R1:fastest
HF_PRIMARY_MODEL=openai/gpt-oss-120b:fastest
HF_FALLBACK_MODEL=deepseek-ai/DeepSeek-R1:fastest

# OAuth + Dashboard onboarding
# Backend/public URLs used by OAuth callbacks
API_BASE_URL=http://127.0.0.1:8086
FRONTEND_URL=http://127.0.0.1:5173

# Google OAuth app credentials
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://127.0.0.1:8086/api/auth/google/callback

# GitHub OAuth app credentials
GITHUB_CLIENT_ID=
GITHUB_CLIENT_SECRET=
GITHUB_REDIRECT_URI=http://127.0.0.1:8086/api/auth/github/callback

# Reusable workflow source repository (owner/repo and ref)
GITHUB_TOOLKIT_REPO=<OWNER>/<REPO>
GITHUB_TOOLKIT_REF=main

# Frontend origin allow-list for credentialed requests
CORS_ORIGINS=http://127.0.0.1:5173,http://localhost:5173

# Production session hardening
SESSION_SECRET=replace_with_long_random_secret
SESSION_DB_PATH=data/sessions.db
SESSION_COOKIE_SECURE=false
SESSION_COOKIE_DOMAIN=
OAUTH_STATE_TTL_SECONDS=900

# Optional: GitHub App install flow (recommended for production)
GITHUB_APP_NAME=

# GitHub Token (optional, for higher API rate limits when scraping logs)
GITHUB_TOKEN=ghp_your_token_here

# MLflow
MLFLOW_TRACKING_URI=mlruns

# App Config
APP_ENV=development
LOG_LEVEL=INFO

# Latency tuning
HF_MAX_TOKENS=320
HF_TIMEOUT_SECONDS=18
HF_MAX_RETRIES=1
HF_RESPONSE_CACHE_SIZE=64
AGENT_MAX_CONTEXT_RESULTS=3
AGENT_MAX_CONTEXT_CHARS=2000
AGENT_MAX_ERROR_SECTION_CHARS=2000
AGENT_MAX_DIAGNOSIS_TOKENS=320
AGENT_MAX_CRITIQUE_TOKENS=96
PRELOAD_RAG_ON_STARTUP=false
PRELOAD_EMBEDDINGS_ON_STARTUP=false
